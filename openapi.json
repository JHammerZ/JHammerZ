{
  "openapi": "3.0.3",
  "info": {
    "title": "Lysander 3.0 Sovereign API",
    "description": "Standardized H-Fid interface for local sovereign orchestration. All external 'voodoo' trackers and siphoned payment hooks have been purged.",
    "version": "1.0.0",
    "contact": {
      "name": "Joshua Hamilton (Master Architect)",
      "url": "https://github.io"
    }
  },
  "servers": [
    {
      "url": "https://github.io",
      "description": "Sovereign Production Gateway"
    }
  ],
  "paths": {
    "/verify/intent": {
      "post": {
        "summary": "Autonomous H-Fid intent verification.",
        "description": "Audits local request integrity against the Springfield Node Alpha root.",
        "responses": {
          "200": {
            "description": "Fidelity Verified & Settled locally.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fidelity_score": { "type": "integer", "example": 100 },
                    "audit_status": { "type": "string", "example": "100/100" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuditResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "H-FID_LOCKED" }
        }
      }
    }
  }
}
